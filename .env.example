PORT=3000
SESSION_SECRET=troque-esta-chave

# Persistencia de dados:
# - Sem DATABASE_URL: usa arquivo local data/store.json (desenvolvimento)
# - Com DATABASE_URL: usa PostgreSQL (recomendado para producao / Supabase)
DATABASE_URL=
DATABASE_SSL=false

# Admin inicial (criado apenas quando nao existe admin no banco/local)
ADMIN_EMAIL=admin@tabela.local
ADMIN_PASSWORD=admin123

# SMTP para notificacao de alteracao de preco
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usuario@seuprovedor.com
SMTP_PASS=senha-ou-token
SMTP_FROM=Tabela de Preco <usuario@seuprovedor.com>

# Opcional para timezone nos emails
TZ=America/Sao_Paulo
